rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function verifiedAccount() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.ativo == true;
    }

    function canModerate() {
      return isAdmin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissoes is map
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissoes.moderarConteudo == true;
    }

    function validUid(value) {
      return value is string
        && value.size() > 5
        && value != 'undefined'
        && value != 'null';
    }

    function candidaturaParticipant(data) {
      return signedIn()
        && (data.jogadorUid == request.auth.uid || data.capitaoUid == request.auth.uid);
    }

    function conviteParticipant(data) {
      return signedIn()
        && (data.jogadorUid == request.auth.uid || data.capitaoUid == request.auth.uid);
    }

    function playerCanUpdateApplication() {
      return verifiedAccount()
        && resource.data.jogadorUid == request.auth.uid
        && request.resource.data.jogadorUid == resource.data.jogadorUid
        && request.resource.data.vagaId == resource.data.vagaId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'capitaoUid', 'clube', 'jogadorNome', 'jogadorFoto', 'posicao',
          'overall', 'status', 'jogadorViu', 'atualizadoEm', 'reenviadoEm',
          'canceladoEm', 'canceladoPor'
        ])
        && (
          (resource.data.status == 'pendente' && request.resource.data.status in ['pendente', 'cancelado'])
          || (resource.data.status in ['recusado', 'cancelado']
            && (request.resource.data.status == resource.data.status || request.resource.data.status == 'pendente'))
          || (resource.data.status == 'aceito' && request.resource.data.status == 'aceito')
        );
    }

    function captainCanAnswerApplication() {
      return verifiedAccount()
        && resource.data.capitaoUid == request.auth.uid
        && request.resource.data.jogadorUid == resource.data.jogadorUid
        && request.resource.data.vagaId == resource.data.vagaId
        && request.resource.data.capitaoUid == request.auth.uid
        && resource.data.status == 'pendente'
        && request.resource.data.status in ['aceito', 'recusado']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'chatId', 'jogadorViu', 'capitaoUid', 'respondidoEm',
          'respondidoPor', 'atualizadoEm'
        ]);
    }

    function inviteCanBeUpdated() {
      return verifiedAccount()
        && request.resource.data.capitaoUid == resource.data.capitaoUid
        && request.resource.data.jogadorUid == resource.data.jogadorUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'chatId', 'respondidoEm', 'respondidoPor', 'atualizadoEm',
          'canceladoEm', 'canceladoPor'
        ])
        && (
          (resource.data.capitaoUid == request.auth.uid
            && resource.data.status == 'pendente'
            && request.resource.data.status == 'cancelado')
          || (resource.data.jogadorUid == request.auth.uid
            && resource.data.status == 'pendente'
            && request.resource.data.status in ['aceito', 'recusado'])
        );
    }

    function chatArchiveOnlyOwnUid() {
      let before = resource.data.get('arquivadoPor', []);
      let after = request.resource.data.get('arquivadoPor', []);
      return before is list
        && after is list
        && after.toSet().difference(before.toSet()).hasOnly([request.auth.uid])
        && before.toSet().difference(after.toSet()).hasOnly([request.auth.uid]);
    }

    match /jogadores/{uid} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly([
          'nickname', 'eaId', 'idEA', 'altura', 'peso', 'overall', 'nivel',
          'clube', 'agenteLivre', 'procurandoClube', 'posicao',
          'posicaoSecundaria', 'plataforma', 'disponibilidade', 'estiloJogo',
          'regiao', 'bio', 'partidas', 'gols', 'assistencias', 'defesas',
          'fotoURL', 'criadoEm', 'atualizadoEm', 'ehCapitao', 'clubeId',
          'clubeAtualId', 'clubeAtualNome'
        ])
        && !request.resource.data.keys().hasAny([
          'email',
          'suspenso', 'suspensoPor', 'suspensoEm', 'motivoSuspensao',
          'reativadoPor', 'reativadoEm'
        ]);
      allow update: if signedIn() && (
        (
          request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'nickname', 'eaId', 'idEA', 'altura', 'peso', 'overall', 'nivel',
            'clube', 'agenteLivre', 'procurandoClube', 'posicao',
            'posicaoSecundaria', 'plataforma', 'disponibilidade', 'estiloJogo',
            'regiao', 'bio', 'partidas', 'gols', 'assistencias', 'defesas',
            'fotoURL', 'criadoEm', 'atualizadoEm', 'ehCapitao', 'clubeId',
            'clubeAtualId', 'clubeAtualNome'
          ])
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'email',
            'suspenso', 'suspensoPor', 'suspensoEm', 'motivoSuspensao',
            'reativadoPor', 'reativadoEm'
          ])
          && (
            resource.data.get('suspenso', false) != true
            || request.resource.data.get('procurandoClube', false) != true
          )
        )
        || (
          canModerate()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'suspenso', 'procurandoClube', 'suspensoPor', 'suspensoEm',
            'motivoSuspensao', 'reativadoPor', 'reativadoEm'
          ])
        )
        || (
          canModerate()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email'])
          && !request.resource.data.keys().hasAny(['email'])
        )
        || (
          resource.data.clubeAtualId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'clubeAtualId', 'clubeAtualNome'
          ])
          && request.resource.data.clubeAtualId == null
          && request.resource.data.clubeAtualNome == null
        )
      );
      allow delete: if signedIn()
        && request.auth.uid == uid
        && resource.data.get('suspenso', false) != true;
    }

    match /jogadoresPrivados/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update: if (
        (signedIn() && request.auth.uid == uid) || canModerate()
      )
        && request.resource.data.keys().hasOnly(['email', 'criadoEm', 'atualizadoEm'])
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 3
        && request.resource.data.email.size() <= 254;
      allow delete: if (signedIn() && request.auth.uid == uid) || canModerate();
    }

    match /clubes/{clubeId} {
      allow read: if true;
      allow create: if verifiedAccount()
        && request.auth.uid == clubeId
        && request.resource.data.capitaoUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'nome', 'capitaoUid', 'plataforma', 'divisao', 'regiao', 'jogo',
          'estiloJogo', 'horarioTreino', 'diasTreino', 'objetivo', 'descricao',
          'discord', 'whatsapp', 'instagram', 'capitaoIdEA',
          'capitaoMicrofone', 'necessidades', 'escudoUrl'
        ])
        && request.resource.data.nome is string
        && request.resource.data.nome.size() > 0
        && request.resource.data.nome.size() <= 100
        && request.resource.data.get('descricao', '') is string
        && request.resource.data.get('descricao', '').size() <= 1500
        && request.resource.data.get('escudoUrl', '') is string
        && request.resource.data.get('escudoUrl', '').size() <= 900000
        && !request.resource.data.keys().hasAny([
          'verificado', 'verificacaoAtualizadaPor', 'verificacaoAtualizadaEm',
          'motivoVerificacao', 'suspenso', 'suspensoPor', 'suspensoEm',
          'motivoSuspensao', 'desbloqueadoPor', 'desbloqueadoEm'
        ]);
      allow update: if (
        verifiedAccount()
        && request.auth.uid == clubeId
        && request.resource.data.capitaoUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nome', 'capitaoUid', 'plataforma', 'divisao', 'regiao', 'jogo',
          'estiloJogo', 'horarioTreino', 'diasTreino', 'objetivo', 'descricao',
          'discord', 'whatsapp', 'instagram', 'capitaoIdEA',
          'capitaoMicrofone', 'necessidades', 'escudoUrl'
        ])
        && request.resource.data.nome is string
        && request.resource.data.nome.size() > 0
        && request.resource.data.nome.size() <= 100
        && request.resource.data.get('descricao', '') is string
        && request.resource.data.get('descricao', '').size() <= 1500
        && request.resource.data.get('escudoUrl', '') is string
        && request.resource.data.get('escudoUrl', '').size() <= 900000
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'verificado', 'verificacaoAtualizadaPor', 'verificacaoAtualizadaEm',
          'motivoVerificacao', 'suspenso', 'suspensoPor', 'suspensoEm',
          'motivoSuspensao', 'desbloqueadoPor', 'desbloqueadoEm'
        ])
      ) || (
        canModerate()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'verificado', 'verificacaoAtualizadaPor', 'verificacaoAtualizadaEm',
          'motivoVerificacao', 'suspenso', 'suspensoPor', 'suspensoEm',
          'motivoSuspensao', 'desbloqueadoPor', 'desbloqueadoEm'
        ])
      );
      allow delete: if (
        verifiedAccount()
        && request.auth.uid == clubeId
        && resource.data.get('suspenso', false) != true
      ) || canModerate();
    }

    match /vagas/{vagaId} {
      allow read: if true;
      allow create: if verifiedAccount()
        && request.resource.data.capitaoUid == request.auth.uid
        && request.resource.data.clube is string
        && request.resource.data.clube.size() > 0
        && request.resource.data.clube.size() <= 100
        && request.resource.data.get('descricao', '') is string
        && request.resource.data.get('descricao', '').size() <= 1200
        && request.resource.data.get('fotosClube', []) is list
        && request.resource.data.get('fotosClube', []).size() <= 3
        && request.resource.data.keys().hasOnly([
          'clube', 'plataforma', 'posicao', 'estilo', 'jogo', 'descricao',
          'overallMinimo', 'fotosClube', 'capitaoUid', 'capitaoNome', 'criadoEm'
        ])
        && exists(/databases/$(database)/documents/clubes/$(request.auth.uid))
        && get(/databases/$(database)/documents/clubes/$(request.auth.uid)).data.get('suspenso', false) != true;
      allow update: if (
        verifiedAccount()
        && resource.data.capitaoUid == request.auth.uid
        && request.resource.data.capitaoUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'clube', 'plataforma', 'posicao', 'estilo', 'jogo', 'descricao',
          'overallMinimo', 'fotosClube', 'criadoEm'
        ])
        && request.resource.data.clube is string
        && request.resource.data.clube.size() > 0
        && request.resource.data.clube.size() <= 100
        && request.resource.data.get('descricao', '') is string
        && request.resource.data.get('descricao', '').size() <= 1200
        && request.resource.data.get('fotosClube', []) is list
        && request.resource.data.get('fotosClube', []).size() <= 3
        && get(/databases/$(database)/documents/clubes/$(request.auth.uid)).data.get('suspenso', false) != true
      ) || canModerate();
      allow delete: if (
        verifiedAccount() && resource.data.capitaoUid == request.auth.uid
      ) || canModerate();
    }

    match /candidaturas/{candidaturaId} {
      allow read: if candidaturaParticipant(resource.data) || isAdmin();
      allow create: if verifiedAccount()
        && request.resource.data.jogadorUid == request.auth.uid
        && validUid(request.resource.data.capitaoUid)
        && request.resource.data.keys().hasOnly([
          'vagaId', 'clube', 'jogadorUid', 'jogadorNome', 'jogadorFoto',
          'posicao', 'overall', 'capitaoUid', 'status', 'jogadorViu',
          'atualizadoEm', 'criadoEm'
        ])
        && request.resource.data.vagaId is string
        && request.resource.data.vagaId.size() > 5
        && request.resource.data.clube is string
        && request.resource.data.clube.size() <= 100
        && request.resource.data.jogadorNome is string
        && request.resource.data.jogadorNome.size() <= 80
        && request.resource.data.jogadorUid != request.resource.data.capitaoUid
        && exists(/databases/$(database)/documents/vagas/$(request.resource.data.vagaId))
        && request.resource.data.capitaoUid == get(/databases/$(database)/documents/vagas/$(request.resource.data.vagaId)).data.capitaoUid
        && request.resource.data.clube == get(/databases/$(database)/documents/vagas/$(request.resource.data.vagaId)).data.clube
        && exists(/databases/$(database)/documents/jogadores/$(request.auth.uid))
        && get(/databases/$(database)/documents/jogadores/$(request.auth.uid)).data.get('suspenso', false) != true
        && (
          get(/databases/$(database)/documents/jogadores/$(request.auth.uid)).data.get('clubeAtualId', null) == null
          || get(/databases/$(database)/documents/jogadores/$(request.auth.uid)).data.get('clubeAtualId', '') == ''
        )
        && request.resource.data.status == 'pendente';
      allow update: if playerCanUpdateApplication() || captainCanAnswerApplication();
      allow delete: if canModerate();
    }

    match /convitesClube/{conviteId} {
      allow read: if conviteParticipant(resource.data) || isAdmin();
      allow create: if verifiedAccount()
        && request.resource.data.capitaoUid == request.auth.uid
        && request.resource.data.jogadorUid != request.auth.uid
        && request.resource.data.status == 'pendente'
        && request.resource.data.keys().hasOnly([
          'capitaoUid', 'clube', 'jogadorUid', 'jogadorNome', 'status',
          'origem', 'criadoEm'
        ])
        && request.resource.data.clube is string
        && request.resource.data.clube.size() > 0
        && request.resource.data.clube.size() <= 100
        && request.resource.data.jogadorNome is string
        && request.resource.data.jogadorNome.size() <= 80
        && exists(/databases/$(database)/documents/clubes/$(request.auth.uid))
        && get(/databases/$(database)/documents/clubes/$(request.auth.uid)).data.get('suspenso', false) != true
        && exists(/databases/$(database)/documents/jogadores/$(request.resource.data.jogadorUid))
        && get(/databases/$(database)/documents/jogadores/$(request.resource.data.jogadorUid)).data.get('suspenso', false) != true;
      allow update: if inviteCanBeUpdated();
      allow delete: if canModerate();
    }

    match /negociacoesArquivadas/{arquivoId} {
      allow read: if signedIn() && resource.data.usuarioUid == request.auth.uid;
      allow create: if verifiedAccount()
        && request.resource.data.usuarioUid == request.auth.uid
        && request.resource.data.tipo in ['candidatura', 'convite']
        && request.resource.data.registroId is string
        && request.resource.data.registroId.size() > 5
        && request.resource.data.keys().hasOnly([
          'usuarioUid', 'tipo', 'registroId', 'criadoEm'
        ]);
      allow update: if false;
      allow delete: if verifiedAccount() && resource.data.usuarioUid == request.auth.uid;
    }

    match /chats/{chatId} {
      allow create: if verifiedAccount()
        && request.resource.data.participantes is list
        && request.resource.data.participantes.size() == 2
        && request.auth.uid in request.resource.data.participantes
        && request.resource.data.participantes[0] != request.resource.data.participantes[1]
        && validUid(request.resource.data.participantes[0])
        && validUid(request.resource.data.participantes[1])
        && exists(/databases/$(database)/documents/jogadores/$(request.resource.data.participantes[0]))
        && exists(/databases/$(database)/documents/jogadores/$(request.resource.data.participantes[1]))
        && request.resource.data.keys().hasOnly([
          'clube', 'participantes', 'tipo', 'criadoEm', 'ultimaMensagemTexto',
          'ultimaMensagemAutorUid', 'ultimaMensagemEm', 'lidoPor', 'arquivadoPor'
        ])
        && request.resource.data.clube is string
        && request.resource.data.clube.size() <= 100
        && request.resource.data.tipo in ['candidatura', 'convite-clube'];
      allow read: if signedIn() && request.auth.uid in resource.data.participantes;
      allow update: if verifiedAccount()
        && request.auth.uid in resource.data.participantes
        && request.resource.data.participantes == resource.data.participantes
        && chatArchiveOnlyOwnUid()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'clube', 'tipo', 'criadoEm', 'ultimaMensagemTexto',
          'ultimaMensagemAutorUid', 'ultimaMensagemEm', 'lidoPor', 'arquivadoPor'
        ]);
      allow delete: if false;

      match /mensagens/{mensagemId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;
        allow create: if verifiedAccount()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes
          && request.resource.data.autorUid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'texto', 'autorUid', 'autorNome', 'enviadoEm'
          ])
          && request.resource.data.texto is string
          && request.resource.data.texto.size() > 0
          && request.resource.data.texto.size() <= 500
          && request.resource.data.autorNome is string
          && request.resource.data.autorNome.size() <= 80;
        allow update, delete: if false;
      }
    }

    match /denuncias/{denunciaId} {
      allow create: if verifiedAccount()
        && request.resource.data.denuncianteUid == request.auth.uid
        && denunciaId == request.auth.uid + '_' + request.resource.data.vagaId
        && request.resource.data.keys().hasOnly([
          'vagaId', 'clube', 'capitaoUid', 'denuncianteUid',
          'motivo', 'detalhes', 'status', 'criadoEm'
        ])
        && request.resource.data.vagaId is string
        && request.resource.data.vagaId.size() > 5
        && request.resource.data.clube is string
        && request.resource.data.capitaoUid is string
        && request.resource.data.motivo in [
          'spam', 'ofensivo', 'falso', 'golpe', 'inadequado', 'outro'
        ]
        && request.resource.data.detalhes is string
        && request.resource.data.detalhes.size() <= 500
        && request.resource.data.status == 'pendente'
        && exists(/databases/$(database)/documents/vagas/$(request.resource.data.vagaId))
        && request.resource.data.capitaoUid == get(/databases/$(database)/documents/vagas/$(request.resource.data.vagaId)).data.capitaoUid
        && request.resource.data.clube == get(/databases/$(database)/documents/vagas/$(request.resource.data.vagaId)).data.clube;
      allow read: if isAdmin()
        || (signedIn() && resource.data.denuncianteUid == request.auth.uid);
      allow update, delete: if canModerate();
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    match /logsAdmin/{logId} {
      allow read: if isAdmin();
      allow create: if canModerate()
        && request.resource.data.adminUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /torneios/{torneioId} {
      allow read: if true;
      allow create, update, delete: if canModerate();

      match /inscricoes/{inscricaoId} {
        allow read: if true;
        allow create: if verifiedAccount()
          && inscricaoId == request.auth.uid
          && request.resource.data.capitaoUid == request.auth.uid
          && request.resource.data.clubeId == request.auth.uid
          && request.resource.data.torneioId == torneioId
          && request.resource.data.status == 'pendente'
          && request.resource.data.keys().hasOnly([
            'torneioId', 'clubeId', 'capitaoUid', 'clubeNome', 'clubeEscudo',
            'plataforma', 'regiao', 'status', 'criadoEm', 'atualizadoEm'
          ])
          && request.resource.data.clubeNome is string
          && request.resource.data.clubeNome.size() > 0
          && request.resource.data.clubeNome.size() <= 100
          && get(/databases/$(database)/documents/torneios/$(torneioId)).data.status == 'aberto'
          && exists(/databases/$(database)/documents/clubes/$(request.auth.uid))
          && get(/databases/$(database)/documents/clubes/$(request.auth.uid)).data.get('suspenso', false) != true;
        allow update: if canModerate()
          && request.resource.data.capitaoUid == resource.data.capitaoUid
          && request.resource.data.clubeId == resource.data.clubeId
          && request.resource.data.torneioId == resource.data.torneioId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'analisadaEm', 'analisadaPor', 'atualizadoEm'
          ])
          && request.resource.data.status in ['pendente', 'aprovada', 'rejeitada'];
        allow delete: if canModerate()
          || (verifiedAccount()
            && inscricaoId == request.auth.uid
            && resource.data.capitaoUid == request.auth.uid
            && resource.data.status == 'pendente');
      }

      match /partidas/{partidaId} {
        allow read: if true;
        allow create, update, delete: if canModerate();

        match /envios/{envioId} {
          function partidaDoTorneio() {
            return get(/databases/$(database)/documents/torneios/$(torneioId)/partidas/$(partidaId)).data;
          }

          function capitaoParticipa() {
            return verifiedAccount()
              && request.auth.uid in [partidaDoTorneio().timeAId, partidaDoTorneio().timeBId];
          }

          function envioDePlacarValido() {
            return request.resource.data.keys().hasOnly([
                'capitaoUid', 'clubeId', 'clubeNome', 'placarA', 'placarB',
                'observacao', 'criadoEm', 'atualizadoEm'
              ])
              && request.resource.data.capitaoUid == request.auth.uid
              && request.resource.data.clubeId == request.auth.uid
              && request.resource.data.clubeNome is string
              && request.resource.data.clubeNome.size() > 0
              && request.resource.data.clubeNome.size() <= 100
              && request.resource.data.clubeNome == (
                request.auth.uid == partidaDoTorneio().timeAId
                  ? partidaDoTorneio().timeANome
                  : partidaDoTorneio().timeBNome
              )
              && request.resource.data.placarA is int
              && request.resource.data.placarB is int
              && request.resource.data.placarA >= 0
              && request.resource.data.placarA <= 99
              && request.resource.data.placarB >= 0
              && request.resource.data.placarB <= 99
              && request.resource.data.placarA != request.resource.data.placarB
              && request.resource.data.observacao is string
              && request.resource.data.observacao.size() <= 240
              && request.resource.data.criadoEm is timestamp
              && request.resource.data.atualizadoEm is timestamp;
          }

          allow get: if canModerate()
            || (capitaoParticipa()
              && (envioId == request.auth.uid
                || exists(/databases/$(database)/documents/torneios/$(torneioId)/partidas/$(partidaId)/envios/$(request.auth.uid))));
          allow list: if canModerate()
            || (capitaoParticipa()
              && exists(/databases/$(database)/documents/torneios/$(torneioId)/partidas/$(partidaId)/envios/$(request.auth.uid)));
          allow create: if capitaoParticipa()
            && envioId == request.auth.uid
            && get(/databases/$(database)/documents/torneios/$(torneioId)).data.status == 'andamento'
            && partidaDoTorneio().status == 'pendente'
            && envioDePlacarValido();
          allow update: if capitaoParticipa()
            && envioId == request.auth.uid
            && resource.data.capitaoUid == request.auth.uid
            && resource.data.clubeId == request.auth.uid
            && request.resource.data.criadoEm == resource.data.criadoEm
            && get(/databases/$(database)/documents/torneios/$(torneioId)).data.status == 'andamento'
            && partidaDoTorneio().status == 'pendente'
            && envioDePlacarValido();
          allow delete: if canModerate();
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
