rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.ativo == true;
    }

    function canModerate() {
      return isAdmin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissoes is map
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.permissoes.moderarConteudo == true;
    }

    function validUid(value) {
      return value is string
        && value.size() > 5
        && value != 'undefined'
        && value != 'null';
    }

    function candidaturaParticipant(data) {
      return signedIn()
        && (data.jogadorUid == request.auth.uid || data.capitaoUid == request.auth.uid);
    }

    function conviteParticipant(data) {
      return signedIn()
        && (data.jogadorUid == request.auth.uid || data.capitaoUid == request.auth.uid);
    }

    function playerCanUpdateApplication() {
      return signedIn()
        && resource.data.jogadorUid == request.auth.uid
        && request.resource.data.jogadorUid == resource.data.jogadorUid
        && request.resource.data.vagaId == resource.data.vagaId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'capitaoUid', 'clube', 'jogadorNome', 'jogadorFoto', 'posicao',
          'overall', 'status', 'jogadorViu', 'atualizadoEm', 'reenviadoEm',
          'canceladoEm', 'canceladoPor'
        ])
        && (
          (resource.data.status == 'pendente' && request.resource.data.status in ['pendente', 'cancelado'])
          || (resource.data.status in ['recusado', 'cancelado']
            && (request.resource.data.status == resource.data.status || request.resource.data.status == 'pendente'))
          || (resource.data.status == 'aceito' && request.resource.data.status == 'aceito')
        );
    }

    function captainCanAnswerApplication() {
      return signedIn()
        && resource.data.capitaoUid == request.auth.uid
        && request.resource.data.jogadorUid == resource.data.jogadorUid
        && request.resource.data.vagaId == resource.data.vagaId
        && request.resource.data.capitaoUid == request.auth.uid
        && resource.data.status == 'pendente'
        && request.resource.data.status in ['aceito', 'recusado']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'chatId', 'jogadorViu', 'capitaoUid', 'respondidoEm',
          'respondidoPor', 'atualizadoEm'
        ]);
    }

    function inviteCanBeUpdated() {
      return signedIn()
        && request.resource.data.capitaoUid == resource.data.capitaoUid
        && request.resource.data.jogadorUid == resource.data.jogadorUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'chatId', 'respondidoEm', 'respondidoPor', 'atualizadoEm',
          'canceladoEm', 'canceladoPor'
        ])
        && (
          (resource.data.capitaoUid == request.auth.uid
            && resource.data.status == 'pendente'
            && request.resource.data.status == 'cancelado')
          || (resource.data.jogadorUid == request.auth.uid
            && resource.data.status == 'pendente'
            && request.resource.data.status in ['aceito', 'recusado'])
        );
    }

    match /jogadores/{uid} {
      allow read: if true;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && (
        request.auth.uid == uid
        || (
          resource.data.clubeAtualId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'clubeAtualId', 'clubeAtualNome'
          ])
          && request.resource.data.clubeAtualId == null
          && request.resource.data.clubeAtualNome == null
        )
      );
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    match /clubes/{clubeId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == clubeId
        && !request.resource.data.keys().hasAny(['verificado']);
      allow update: if (
        signedIn()
        && request.auth.uid == clubeId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verificado'])
      ) || canModerate();
      allow delete: if (signedIn() && request.auth.uid == clubeId) || canModerate();
    }

    match /vagas/{vagaId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.capitaoUid == request.auth.uid
        && request.resource.data.clube is string;
      allow update: if (
        signedIn()
        && resource.data.capitaoUid == request.auth.uid
        && request.resource.data.capitaoUid == request.auth.uid
      ) || canModerate();
      allow delete: if (
        signedIn() && resource.data.capitaoUid == request.auth.uid
      ) || canModerate();
    }

    match /candidaturas/{candidaturaId} {
      allow read: if candidaturaParticipant(resource.data) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.jogadorUid == request.auth.uid
        && validUid(request.resource.data.capitaoUid)
        && request.resource.data.status == 'pendente';
      allow update: if playerCanUpdateApplication() || captainCanAnswerApplication();
      allow delete: if false;
    }

    match /convitesClube/{conviteId} {
      allow read: if conviteParticipant(resource.data) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.capitaoUid == request.auth.uid
        && request.resource.data.jogadorUid != request.auth.uid
        && request.resource.data.status == 'pendente'
        && exists(/databases/$(database)/documents/clubes/$(request.auth.uid));
      allow update: if inviteCanBeUpdated();
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow create: if signedIn()
        && request.resource.data.participantes is list
        && request.resource.data.participantes.size() == 2
        && request.auth.uid in request.resource.data.participantes;
      allow read: if signedIn() && request.auth.uid in resource.data.participantes;
      allow update: if signedIn()
        && request.auth.uid in resource.data.participantes
        && request.resource.data.participantes == resource.data.participantes
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'clube', 'tipo', 'criadoEm', 'ultimaMensagemTexto',
          'ultimaMensagemAutorUid', 'ultimaMensagemEm', 'lidoPor', 'arquivadoPor'
        ]);
      allow delete: if false;

      match /mensagens/{mensagemId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;
        allow create: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes
          && request.resource.data.autorUid == request.auth.uid
          && request.resource.data.texto is string
          && request.resource.data.texto.size() > 0
          && request.resource.data.texto.size() <= 500;
        allow update, delete: if false;
      }
    }

    match /denuncias/{denunciaId} {
      allow create: if signedIn()
        && request.resource.data.denuncianteUid == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if canModerate();
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create, update, delete: if false;
    }

    match /logsAdmin/{logId} {
      allow read: if isAdmin();
      allow create: if canModerate()
        && request.resource.data.adminUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /torneios/{torneioId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.criadorUid == request.auth.uid;
      allow update, delete: if (
        signedIn() && resource.data.criadorUid == request.auth.uid
      ) || canModerate();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
